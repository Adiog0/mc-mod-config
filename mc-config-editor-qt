#!/usr/bin/env bash
# mc-config-editor-qt — Launcher PyQt6 (usa venv)
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

VENV_PYTHON="$HOME/.cache/mc-config-editor-venv/bin/python3"
if [ ! -f "$VENV_PYTHON" ]; then
    # Fallback: projet-local venv
    for candidate in "$SCRIPT_DIR/venv/bin/python3" "$SCRIPT_DIR/.venv/bin/python3"; do
        if [ -f "$candidate" ]; then VENV_PYTHON="$candidate"; break; fi
    done
fi

if [ ! -f "$VENV_PYTHON" ]; then
    echo "❌ Virtualenv nao encontrado." >&2
    echo "   Execute: python3 -m venv \$HOME/.cache/mc-config-editor-venv" >&2
    echo "   Depois: \$VENV_PYTHON -m pip install customtkinter tomlkit pyjson5 pyyaml PyQt6" >&2
    exit 1
fi

LOGDIR="$SCRIPT_DIR/logs"
mkdir -p "$LOGDIR"

echo "🚀 Iniciando Minecraft Mod Config Editor (PyQt6)..."
echo "   OS:      $(uname -s)"
echo "   Python:  $VENV_PYTHON"
echo "   Logs:    $LOGDIR/"
echo ""

exec "$VENV_PYTHON" "$SCRIPT_DIR/mc-config-editor-qt.py" "$@"
