#!/usr/bin/env bash
# mc-config-editor — Launcher multiplataforma
# Funciona em Linux e macOS. No Windows use mc-config-editor.bat
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

VENV_PYTHON=""
for candidate in \
    "$SCRIPT_DIR/venv/bin/python3" \
    "$SCRIPT_DIR/venv/bin/python" \
    "$SCRIPT_DIR/.venv/bin/python3" \
    "$HOME/.cache/mc-config-editor-venv/bin/python3"; do
    if [ -f "$candidate" ]; then VENV_PYTHON="$candidate"; break; fi
done

if [ -z "$VENV_PYTHON" ]; then
    VENV_PYTHON="python3"
fi

LOGDIR="$SCRIPT_DIR/logs"
mkdir -p "$LOGDIR"

echo "🚀 Minecraft Mod Config Editor"
echo "   OS:      $(uname -s)"
echo "   Python:  $VENV_PYTHON"
echo "   Logs:    $LOGDIR/"
echo ""

exec "$VENV_PYTHON" "$SCRIPT_DIR/mc-config-editor.py" "$@"
