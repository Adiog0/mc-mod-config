#!/usr/bin/env bash
# mc-config-editor — Launcher principal (PyQt6)
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Procura venv local ou cache
for candidate in \
    "$SCRIPT_DIR/venv/bin/python3" \
    "$SCRIPT_DIR/venv/bin/python" \
    "$SCRIPT_DIR/.venv/bin/python3" \
    "$HOME/.cache/mc-config-editor-venv/bin/python3"; do
    if [ -f "$candidate" ]; then
        VENV_PYTHON="$candidate"
        break
    fi
done

if [ -z "${VENV_PYTHON:-}" ]; then
    echo "❌ Virtualenv nao encontrado." >&2
    echo "   Crie um venv:" >&2
    echo "     cd '$SCRIPT_DIR' && python3 -m venv venv" >&2
    echo "     ./venv/bin/pip install customtkinter tomlkit pyjson5 pyyaml PyQt6" >&2
    exit 1
fi

LOGDIR="$SCRIPT_DIR/logs"
mkdir -p "$LOGDIR"

echo "🚀 Iniciando Minecraft Mod Config Editor (PyQt6)..."
echo "   OS:      $(uname -s)"
echo "   Python:  $VENV_PYTHON"
echo "   Logs:    $LOGDIR/"
echo ""

exec "$VENV_PYTHON" "$SCRIPT_DIR/mc-config-editor-qt.py" "$@"
